# Production Environment Variables for Letsee
# Copy this file to .env.prod and customize for production deployment

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_USER=letsee_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=letsee

# ============================================================================
# DOMAIN & CORS
# ============================================================================
DOMAIN=your-domain.com
ACME_EMAIL=admin@your-domain.com

# ============================================================================
# SECURITY - CRITICAL!
# ============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_SECURE_KEY

# ============================================================================
# MINIO S3 STORAGE
# ============================================================================
MINIO_ROOT_USER=letsee_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
MINIO_BUCKET=letsee-attachments

# ============================================================================
# GRAFANA MONITORING
# ============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================
WEB_CONCURRENCY=2
